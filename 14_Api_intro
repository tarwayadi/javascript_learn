//understanding object de-structure
/**
 * Object destructuring is a modern ES6 feature that allows you to extract values from objects easily into variables.
 */

const course = {
    coursename: "js-in-hindi",
    price: "zero",
    courseInstructor : "hitesh"
}
//method 1
const{courseInstructor} = course
console.log(courseInstructor)
//method 2
const{courseInstructor : instructor} = course
console.log(instructor)
// both method will have same output


